generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// AUTENTICAÇÃO & USUÁRIOS
// ========================================

enum UserRole {
  CUSTOMER
  ADMIN
  KITCHEN
  DELIVERY
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  cpf           String?   @unique
  passwordHash  String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  addresses    Address[]
  orders       Order[]
  employeeInfo Employee?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ========================================
// CLIENTES GUEST (sem cadastro)
// ========================================

model GuestCustomer {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now())

  orders Order[]

  @@map("guest_customers")
}

// ========================================
// ENDEREÇOS
// ========================================

model Address {
  id          String   @id @default(cuid())
  userId      String?
  cep         String
  logradouro  String
  numero      String
  complemento String?
  bairro      String
  cidade      String
  uf          String   @db.VarChar(2)
  referencia  String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ========================================
// CATÁLOGO DE PRODUTOS
// ========================================

enum CategoryType {
  PIZZA
  BEVERAGE
  SIDE
  DESSERT
}

model Category {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  image       String?
  sortOrder   Int          @default(0)
  isActive    Boolean      @default(true)
  type        CategoryType @default(PIZZA)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  products Product[]

  @@map("categories")
}

enum PizzaSize {
  PEQUENA
  MEDIA
  GRANDE
  GIGANTE
}

model Product {
  id          String   @id @default(cuid())
  categoryId  String
  name        String
  slug        String   @unique
  description String?  @db.Text
  isActive    Boolean  @default(true)
  isHalfHalf  Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category         Category            @relation(fields: [categoryId], references: [id])
  sizes            ProductSize[]
  images           ProductImage[]
  recipe           ProductIngredient[]
  orderItems       OrderItem[]         @relation("ProductOrderItems")
  orderItemsAsHalf OrderItem[]         @relation("HalfProductOrderItems")

  @@index([categoryId])
  @@map("products")
}

model ProductSize {
  id        String    @id @default(cuid())
  productId String
  size      PizzaSize
  price     Decimal   @db.Decimal(10, 2)
  isActive  Boolean   @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
  @@map("product_sizes")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ========================================
// INGREDIENTES & ESTOQUE
// ========================================

enum IngredientUnit {
  GRAMAS
  QUILOGRAMAS
  MILILITROS
  LITROS
  UNIDADE
  PORCAO
  FATIA
}

model Ingredient {
  id           String         @id @default(cuid())
  name         String         @unique
  unit         IngredientUnit
  costPerUnit  Decimal        @db.Decimal(10, 4)
  currentStock Decimal        @db.Decimal(10, 3) @default(0)
  minimumStock Decimal        @db.Decimal(10, 3) @default(0)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  recipes      ProductIngredient[]
  transactions InventoryTransaction[]

  @@map("ingredients")
}

model ProductIngredient {
  id           String    @id @default(cuid())
  productId    String
  ingredientId String
  size         PizzaSize
  quantity     Decimal   @db.Decimal(10, 3)

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([productId, ingredientId, size])
  @@map("product_ingredients")
}

enum InventoryTransactionType {
  ENTRADA
  SAIDA_PEDIDO
  SAIDA_MANUAL
  AJUSTE
  DESCARTE
}

model InventoryTransaction {
  id            String                   @id @default(cuid())
  ingredientId  String
  type          InventoryTransactionType
  quantity      Decimal                  @db.Decimal(10, 3)
  previousStock Decimal                  @db.Decimal(10, 3)
  newStock      Decimal                  @db.Decimal(10, 3)
  orderId       String?
  note          String?
  createdBy     String?
  createdAt     DateTime                 @default(now())

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  order      Order?     @relation(fields: [orderId], references: [id])

  @@index([ingredientId])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ========================================
// PEDIDOS
// ========================================

enum OrderStatus {
  RECEBIDO
  CONFIRMADO
  PREPARANDO
  NO_FORNO
  SAIU_ENTREGA
  ENTREGUE
  CANCELADO
}

enum OrderType {
  DELIVERY
  RETIRADA
}

model Order {
  id                String      @id @default(cuid())
  code              String      @unique
  userId            String?
  guestCustomerId   String?
  addressId         String?
  orderType         OrderType   @default(DELIVERY)
  status            OrderStatus @default(RECEBIDO)
  subtotal          Decimal     @db.Decimal(10, 2)
  deliveryFee       Decimal     @db.Decimal(10, 2) @default(0)
  discount          Decimal     @db.Decimal(10, 2) @default(0)
  total             Decimal     @db.Decimal(10, 2)
  couponId          String?
  note              String?     @db.Text
  estimatedDelivery DateTime?
  deliveryDriverId  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user                  User?          @relation(fields: [userId], references: [id])
  guestCustomer         GuestCustomer? @relation(fields: [guestCustomerId], references: [id])
  address               Address?       @relation(fields: [addressId], references: [id])
  coupon                Coupon?        @relation(fields: [couponId], references: [id])
  deliveryDriver        Employee?      @relation("DriverOrders", fields: [deliveryDriverId], references: [id])
  items                 OrderItem[]
  statusHistory         OrderStatusHistory[]
  payment               Payment?
  inventoryTransactions InventoryTransaction[]

  @@index([userId])
  @@index([guestCustomerId])
  @@index([status])
  @@index([createdAt])
  @@index([code])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(cuid())
  orderId       String
  productId     String
  halfProductId String?
  size          PizzaSize
  quantity      Int       @default(1)
  unitPrice     Decimal   @db.Decimal(10, 2)
  totalPrice    Decimal   @db.Decimal(10, 2)
  note          String?

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation("ProductOrderItems", fields: [productId], references: [id])
  halfProduct Product? @relation("HalfProductOrderItems", fields: [halfProductId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  changedBy String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

// ========================================
// PAGAMENTOS
// ========================================

enum PaymentMethod {
  PIX_ONLINE
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX_ENTREGA
  DINHEIRO
  CARTAO_ENTREGA
}

enum PaymentStatus {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
  REEMBOLSADO
  EM_ANALISE
}

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @unique
  method        PaymentMethod
  status        PaymentStatus @default(PENDENTE)
  amount        Decimal       @db.Decimal(10, 2)
  mercadoPagoId String?
  pixQrCode     String?       @db.Text
  pixCopiaECola String?       @db.Text
  changeFor     Decimal?      @db.Decimal(10, 2)
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([mercadoPagoId])
  @@map("payments")
}

// ========================================
// FINANCEIRO / CAIXA
// ========================================

enum CashRegisterStatus {
  ABERTO
  FECHADO
}

model CashRegister {
  id             String             @id @default(cuid())
  openedBy       String
  closedBy       String?
  status         CashRegisterStatus @default(ABERTO)
  openingAmount  Decimal            @db.Decimal(10, 2)
  closingAmount  Decimal?           @db.Decimal(10, 2)
  expectedAmount Decimal?           @db.Decimal(10, 2)
  difference     Decimal?           @db.Decimal(10, 2)
  openedAt       DateTime           @default(now())
  closedAt       DateTime?
  note           String?

  transactions CashTransaction[]

  @@index([openedAt])
  @@map("cash_registers")
}

enum CashTransactionType {
  VENDA
  DESPESA
  SANGRIA
  SUPRIMENTO
  TROCO_INICIAL
}

model CashTransaction {
  id             String              @id @default(cuid())
  cashRegisterId String
  type           CashTransactionType
  amount         Decimal             @db.Decimal(10, 2)
  paymentMethod  PaymentMethod?
  description    String?
  orderId        String?
  createdBy      String?
  createdAt      DateTime            @default(now())

  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id])

  @@index([cashRegisterId])
  @@index([createdAt])
  @@map("cash_transactions")
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  description String
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime
  isRecurring Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@map("expenses")
}

// ========================================
// FUNCIONÁRIOS
// ========================================

enum EmployeeRole {
  ENTREGADOR
  COZINHEIRO
  ATENDENTE
  GERENTE
}

model Employee {
  id        String       @id @default(cuid())
  userId    String       @unique
  role      EmployeeRole
  isActive  Boolean      @default(true)
  phone     String?
  vehicle   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  orders Order[] @relation("DriverOrders")

  @@map("employees")
}

// ========================================
// ENTREGAS
// ========================================

model DeliveryZone {
  id               String   @id @default(cuid())
  name             String
  neighborhoods    String[]
  fee              Decimal  @db.Decimal(10, 2)
  estimatedMinutes Int      @default(40)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("delivery_zones")
}

// ========================================
// PROMOÇÕES & CUPONS
// ========================================

enum DiscountType {
  PERCENTAGE
  FIXED
  FREE_DELIVERY
}

model Promotion {
  id            String       @id @default(cuid())
  title         String
  description   String?      @db.Text
  image         String?
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  isActive      Boolean      @default(true)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("promotions")
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Decimal      @db.Decimal(10, 2)
  minOrderValue Decimal?     @db.Decimal(10, 2)
  maxUses       Int?
  currentUses   Int          @default(0)
  isActive      Boolean      @default(true)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders Order[]

  @@map("coupons")
}

// ========================================
// CONFIGURAÇÕES
// ========================================

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
  type  String @default("string")

  @@map("settings")
}
